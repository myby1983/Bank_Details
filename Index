<iframe
  id="bankFormFrame"
  src="https://script.google.com/macros/s/AKfycbwOoqpWA0-Mann373teGbwmzkdbFrPFqz0dCizU40RrZ0_qDGRTR_7SxzyQ-p9N3vgh/exec"
  width="100%"
  style="width:100%; border:0; display:block; min-height:620px;"
  scrolling="no">
</iframe>

<script>
window.addEventListener('message', function (e) {
  if (e.data && e.data.type === 'resize' && e.data.height) {
    document.getElementById('bankFormFrame').style.height = e.data.height + 'px';
  }
});
</script>
