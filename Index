<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Booth Verification System</title>
  <style>
    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
    }
<iframe
  id="bankFormFrame"
  src="https://script.google.com/macros/s/AKfycbyoqt0YOkYx1u71rd3oTWsjoJ8ZCrTw7teAzcTPmzBiR0anO8x6n0BJ7NTk9UBahea-/exec"
  width="100%"
  style="border:0; min-height:520px; border-radius:16px;"
  scrolling="no">
</iframe>

<script>
window.addEventListener('message', function (e) {
  if (e.data && e.data.type === 'resize' && e.data.height) {
    const frame = document.getElementById('bankFormFrame');
    frame.style.height = e.data.height + 'px';
  }
});
</script>
</html>
